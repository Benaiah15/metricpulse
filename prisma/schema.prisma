generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  service   String
  message   String
  severity  String   

  @@index([severity])
  @@index([timestamp(sort: Desc)]) 
}

// Add this new model for the real-time charts
model ServerMetric {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  cpu       Float
  memory    Float
  latency   Int

  @@index([timestamp(sort: Desc)])
}